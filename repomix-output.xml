.search input{font-size:14px;font-weight:400;line-height:1.45}
.pagebar,.pagebar select,#rangeInfo{font-size:12.5px;line-height:1.4}
table.grid th{font-size:13px;font-weight:800;line-height:1.35}
table.grid th{padding:10px 14px}
table.grid td{padding:8px 14px;font-size:15px;font-weight:400;line-height:1.4}
table.grid td.name{font-weight:400;line-height:1.5}
.row-action{font-size:13px;font-weight:700}
.mono{font-size:13.5px;line-height:1.45}
.small{font-size:12.5px;line-height:1.45}

@media print{
  .no-print,.sidebar,.foot,.crumb{display:none!important}
  body.app{display:block}body{background:#fff;font-size:14px}.container{padding:0;width:100%}.card{border:0;padding:0;box-shadow:none}.stmt-grid{gap:32px}.stmt-head{display:block}.period-badge{box-shadow:none;border:0;padding:0;text-align:left}.fs td{font-size:13px}.fs td.amt{font-size:12px}
}

/* ===== auth / login ===== */
.authpage{display:flex; align-items:center; justify-content:center; min-height:100vh; padding:24px}
.authcard{width:100%; max-width:400px; background:var(--surface,#fff); border:1px solid var(--line); border-radius:var(--radius,18px); box-shadow:var(--shadow,0 18px 45px rgba(15,23,42,.08)); padding:34px 32px}
.authcard h1{font-size:26px; margin:18px 0 2px}
.authbrand{display:flex; gap:12px; align-items:center; font-weight:800; font-size:18px; color:var(--ink)}
.authbrand .logo{width:44px; height:44px; display:grid; place-items:center; border-radius:14px; color:#fff; font-size:15px; font-weight:800; background:linear-gradient(135deg,var(--brand),var(--brand-2,#0ea5e9)); box-shadow:0 12px 28px rgba(37,99,235,.28)}
.authbrand small{display:block; color:var(--muted); font-size:12px; font-weight:500; letter-spacing:.05em}
.authform{display:flex; flex-direction:column; gap:14px; margin-top:18px}
