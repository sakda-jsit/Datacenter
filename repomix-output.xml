    public async Task Handle(UpdateTaskStatusCommand request, CancellationToken ct)
    {
        var task = await db.ComplianceTasks.FindAsync([request.TaskId], ct)
            ?? throw new NotFoundException("ComplianceTask", request.TaskId);

