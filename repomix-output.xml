        builder.HasOne(t => t.AssignedUser)
               .WithMany()
               .HasForeignKey(t => t.AssignedUserId)
               .OnDelete(DeleteBehavior.SetNull);

        builder.HasOne(t => t.CompletedByUser)
               .WithMany()
               .HasForeignKey(t => t.CompletedByUserId)
               .OnDelete(DeleteBehavior.SetNull);
    }
}
