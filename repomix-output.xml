        // Map: THINAM→ThaiName, ENGNAM→EngName, TAXID→TaxId, VATRAT→VatRate, YEARTHAI→YearThai
        throw new NotImplementedException(
            "ExpressDbfAdapter.ReadCompanyInfoAsync — install dBASE.NET package to implement DBF reading.");
    }

    public Task<IReadOnlyList<ExpressAccountRowDto>> ReadAccountsAsync(string companyFolderPath, CancellationToken ct = default)
    {
        // TODO: Read GLACC.DBF with dBASE.NET (encoding cp874).
        // Skip rows where ACCNUM is blank. Map GROUP int, ACCTYP int.
        throw new NotImplementedException(
            "ExpressDbfAdapter.ReadAccountsAsync — install dBASE.NET package to implement DBF reading.");
    }

    public Task<IReadOnlyList<ExpressTrialBalanceRowDto>> ReadTrialBalanceAsync(string companyFolderPath, CancellationToken ct = default)
    {
        // TODO: Read GLBAL.DBF with dBASE.NET (encoding cp874).
        //
        // For each GLBAL record with non-blank ACCNUM, produce 3 rows (LY, CUR, NY):
        //
        // LY row:
        //   BeginBalance  = BEGLY
        //   TotalDebit    = SUM(DEBIT1LY .. DEBIT12LY)
        //   TotalCredit   = SUM(CREDIT1LY .. CREDIT12LY)
        //   ClosingDebit  = 0
        //   ClosingCredit = 0
        //   EndBalance    = BeginBalance + TotalDebit - TotalCredit
        //
        // CUR row:
        //   BeginBalance  = LY.EndBalance
        //   TotalDebit    = SUM(DEBIT1 .. DEBIT12)
        //   TotalCredit   = SUM(CREDIT1 .. CREDIT12)
        //   ClosingDebit  = DEBITCLS
        //   ClosingCredit = CREDITCLS
        //   EndBalance    = BeginBalance + ClosingDebit - ClosingCredit + TotalDebit - TotalCredit
        //
        // NY row:
        //   BeginBalance  = CUR.EndBalance
        //   TotalDebit    = SUM(DEBIT1NY .. DEBIT12NY)
        //   TotalCredit   = SUM(CREDIT1NY .. CREDIT12NY)
        //   ClosingDebit  = 0
        //   ClosingCredit = 0
        //   EndBalance    = BeginBalance + TotalDebit - TotalCredit
        //
        // All numeric fields: treat null/missing as 0.0 before arithmetic.
        // Round EndBalance to 2 decimal places.
        throw new NotImplementedException(
