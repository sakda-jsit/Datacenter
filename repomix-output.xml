<file path="src/frontend/src/features/import/pages/ImportPage.tsx">
import { useState } from 'react'
import { Link } from 'react-router-dom'
import { useClientList } from '../../clients/hooks/useClients'
import { useImportHistory, useStartExpressImport } from '../hooks/useImport'
import type { ImportBatchListDto, ImportStatus } from '../types/import.types'

const STATUS_LABEL: Record<ImportStatus, string> = {
  Pending: 'รอดำเนินการ',
  Running: 'กำลังนำเข้า',
  Success: 'สำเร็จ',
  Failed: 'มีข้อผิดพลาด',
  Cancelled: 'ยกเลิก',
}

const STATUS_COLOR: Record<ImportStatus, string> = {
  Pending: 'bg-yellow-100 text-yellow-700',
  Running: 'bg-blue-100 text-blue-700',
  Success: 'bg-green-100 text-green-700',
  Failed: 'bg-red-100 text-red-700',
  Cancelled: 'bg-gray-100 text-gray-500',
}

export default function ImportPage() {
  const [filterClientId, setFilterClientId] = useState<number | undefined>()
  const [filterYear, setFilterYear] = useState<number | undefined>()
  const [page, setPage] = useState(1)

  // For "new import" form
  const [showForm, setShowForm] = useState(false)
  const [formClientId, setFormClientId] = useState('')
  const [formYear, setFormYear] = useState(String(new Date().getFullYear()))

  const { data: clients } = useClientList({ pageSize: 200 })
  const { data: history, isLoading } = useImportHistory({
    clientCompanyId: filterClientId,
    fiscalYear: filterYear,
    pageNumber: page,
    pageSize: 20,
  })
  const startImport = useStartExpressImport()

  async function handleStartImport(e: React.FormEvent) {
    e.preventDefault()
    if (!formClientId) return
    try {
      await startImport.mutateAsync({
        clientCompanyId: Number(formClientId),
        fiscalYear: Number(formYear),
      })
      setShowForm(false)
      setFormClientId('')
    } catch {
      // error shown by mutation state
    }
  }

  return (
    <div>
      <div className="flex items-center justify-between mb-6">
        <h1 className="text-2xl font-bold text-slate-800">นำเข้าข้อมูล</h1>
        <button
          onClick={() => setShowForm((v) => !v)}
          className="bg-slate-800 text-white px-4 py-2 rounded text-sm font-medium hover:bg-slate-700"
        >
          + นำเข้าข้อมูลใหม่
        </button>
      </div>

      {/* Import Form */}
      {showForm && (
        <div className="bg-white rounded-lg shadow p-5 mb-6 border-l-4 border-slate-500">
          <h2 className="font-semibold text-slate-800 mb-4">นำเข้าข้อมูลจาก Express DBF</h2>
          <form onSubmit={handleStartImport} className="flex flex-wrap gap-4 items-end">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">บริษัทลูกค้า *</label>
              <select
                value={formClientId}
                onChange={(e) => setFormClientId(e.target.value)}
                required
                className="border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400 w-64"
              >
                <option value="">-- เลือกบริษัท --</option>
                {clients?.items.filter(c => c.isActive).map((c) => (
                  <option key={c.id} value={c.id}>{c.code} — {c.name}</option>
                ))}
              </select>
            </div>

            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">ปีบัญชี (AD) *</label>
              <input
                type="number"
                value={formYear}
                onChange={(e) => setFormYear(e.target.value)}
                min={2000}
                max={2100}
                required
                className="border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400 w-32"
              />
            </div>

            <div className="flex gap-2">
              <button
                type="submit"
                disabled={startImport.isPending}
                className="bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700 disabled:opacity-50"
              >
                {startImport.isPending ? 'กำลังนำเข้า...' : 'เริ่มนำเข้า'}
              </button>
              <button
                type="button"
                onClick={() => setShowForm(false)}
                className="border px-4 py-2 rounded text-sm text-gray-600 hover:bg-gray-50"
              >
                ยกเลิก
              </button>
            </div>
          </form>
          {startImport.isError && (
            <p className="text-red-500 text-sm mt-2">เกิดข้อผิดพลาด: กรุณาตรวจสอบการตั้งค่า Express path</p>
          )}
        </div>
      )}

      {/* Filters */}
      <div className="flex gap-3 mb-4">
        <select
          value={filterClientId ?? ''}
          onChange={(e) => { setFilterClientId(e.target.value ? Number(e.target.value) : undefined); setPage(1) }}
          className="border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400 w-56"
        >
          <option value="">ทุกบริษัท</option>
          {clients?.items.map((c) => (
            <option key={c.id} value={c.id}>{c.code} — {c.name}</option>
          ))}
        </select>

        <input
          type="number"
          placeholder="ปีบัญชี"
          value={filterYear ?? ''}
          onChange={(e) => { setFilterYear(e.target.value ? Number(e.target.value) : undefined); setPage(1) }}
          className="border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400 w-28"
        />
      </div>

      {/* History Table */}
      {isLoading && <p className="text-gray-500 text-sm">กำลังโหลด...</p>}

      {history && (
        <>
          <div className="bg-white rounded-lg shadow overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-slate-50 border-b">
                <tr>
                  <th className="text-left px-4 py-3 font-medium text-gray-600">บริษัท</th>
                  <th className="text-left px-4 py-3 font-medium text-gray-600">ปีบัญชี</th>
                  <th className="text-left px-4 py-3 font-medium text-gray-600">ประเภท</th>
                  <th className="text-left px-4 py-3 font-medium text-gray-600">สถานะ</th>
                  <th className="text-right px-4 py-3 font-medium text-gray-600">รวม</th>
                  <th className="text-right px-4 py-3 font-medium text-gray-600">สำเร็จ</th>
                  <th className="text-right px-4 py-3 font-medium text-gray-600">ผิดพลาด</th>
                  <th className="text-left px-4 py-3 font-medium text-gray-600">นำเข้าโดย</th>
                  <th className="text-left px-4 py-3 font-medium text-gray-600">เวลา</th>
                  <th className="px-4 py-3"></th>
                </tr>
              </thead>
              <tbody className="divide-y divide-gray-100">
                {history.items.length === 0 && (
                  <tr>
                    <td colSpan={10} className="px-4 py-8 text-center text-gray-400">ยังไม่มีประวัติการนำเข้า</td>
                  </tr>
                )}
                {history.items.map((b) => (
                  <ImportBatchRow key={b.id} batch={b} />
                ))}
              </tbody>
            </table>
          </div>

          <div className="flex items-center justify-between mt-4 text-sm text-gray-600">
            <span>ทั้งหมด {history.totalCount} รายการ</span>
            <div className="flex gap-2">
              <button
                disabled={page <= 1}
                onClick={() => setPage(p => p - 1)}
                className="px-3 py-1 border rounded disabled:opacity-40 hover:bg-gray-50"
              >
                ก่อนหน้า
              </button>
              <span className="px-3 py-1">หน้า {history.pageNumber} / {history.totalPages}</span>
              <button
                disabled={page >= history.totalPages}
                onClick={() => setPage(p => p + 1)}
                className="px-3 py-1 border rounded disabled:opacity-40 hover:bg-gray-50"
              >
                ถัดไป
              </button>
            </div>
          </div>
        </>
      )}
    </div>
  )
}

function ImportBatchRow({ batch }: { batch: ImportBatchListDto }) {
  const createdAt = new Date(batch.createdAt).toLocaleString('th-TH', {
    day: '2-digit', month: '2-digit', year: '2-digit',
    hour: '2-digit', minute: '2-digit',
  })

  return (
    <tr className="hover:bg-gray-50">
      <td className="px-4 py-3">
        <span className="font-mono text-slate-700 text-xs">{batch.clientCode}</span>
        <span className="text-gray-500 ml-1 text-xs">{batch.clientName}</span>
      </td>
      <td className="px-4 py-3 font-mono">{batch.fiscalYear}</td>
      <td className="px-4 py-3 text-gray-600">{batch.importType}</td>
      <td className="px-4 py-3">
        <span className={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${STATUS_COLOR[batch.status]}`}>
          {STATUS_LABEL[batch.status]}
        </span>
      </td>
      <td className="px-4 py-3 text-right font-mono">{batch.totalRows.toLocaleString()}</td>
      <td className="px-4 py-3 text-right font-mono text-green-700">{batch.successRows.toLocaleString()}</td>
      <td className="px-4 py-3 text-right font-mono text-red-600">{batch.errorRows > 0 ? batch.errorRows.toLocaleString() : '—'}</td>
      <td className="px-4 py-3 text-gray-500 text-xs">{batch.createdBy}</td>
      <td className="px-4 py-3 text-gray-500 text-xs whitespace-nowrap">{createdAt}</td>
      <td className="px-4 py-3 text-right">
        {batch.errorRows > 0 && (
          <Link
            to={`/import/${batch.id}/validation`}
            className="text-red-600 hover:text-red-800 text-xs font-medium"
          >
            ดูข้อผิดพลาด
          </Link>
        )}
        {batch.status === 'Success' && (
          <Link
            to={`/import/${batch.id}/validation`}
            className="text-blue-600 hover:text-blue-800 text-xs font-medium"
          >
            รายละเอียด
          </Link>
        )}
      </td>
    </tr>
  )
}
