<file path="reference/financial/build_doc.py">
# -*- coding: utf-8 -*-
"""สร้างเอกสารแนวทางพัฒนา Web Application (JSP CONNX) เป็นไฟล์ Word"""
import os
from docx import Document
from docx.shared import Pt, RGBColor, Inches
from docx.enum.text import WD_ALIGN_PARAGRAPH
from docx.oxml.ns import qn

HERE = os.path.dirname(os.path.abspath(__file__))
OUT = os.path.join(HERE, "..", "JSPC_WebApp_Guideline.docx")
FONT = "TH Sarabun New"

doc = Document()
# ตั้งฟอนต์ไทยทั้งเอกสาร
st = doc.styles["Normal"]
st.font.name = FONT
st.font.size = Pt(14)
st.element.rPr.rFonts.set(qn("w:cs"), FONT)
st.element.rPr.rFonts.set(qn("w:eastAsia"), FONT)

NAVY = RGBColor(0x1F, 0x38, 0x64)


def _setfont(run, size=14, bold=False, color=None):
    run.font.name = FONT
    run.font.size = Pt(size)
    run.bold = bold
    if color:
        run.font.color.rgb = color
    rpr = run._element.get_or_add_rPr()
    rf = rpr.get_or_add_rFonts()
    rf.set(qn("w:cs"), FONT)
    rf.set(qn("w:ascii"), FONT)
    rf.set(qn("w:hAnsi"), FONT)


def h(text, size=16, space_before=10):
    p = doc.add_paragraph()
    p.paragraph_format.space_before = Pt(space_before)
    p.paragraph_format.space_after = Pt(4)
    _setfont(p.add_run(text), size, True, NAVY)
    return p


def para(text, size=14, bold=False, align=None, after=4):
    p = doc.add_paragraph()
    p.paragraph_format.space_after = Pt(after)
    if align:
        p.alignment = align
    _setfont(p.add_run(text), size, bold)
    return p


def bullet(text, size=14):
    p = doc.add_paragraph(style="List Bullet")
    _setfont(p.add_run(text), size)
    return p


def table(headers, rows, widths=None):
    t = doc.add_table(rows=1, cols=len(headers))
    t.style = "Light Grid Accent 1"
    for i, hd in enumerate(headers):
        c = t.rows[0].cells[i]
        c.paragraphs[0].clear()
        _setfont(c.paragraphs[0].add_run(hd), 13, True)
    for row in rows:
        cells = t.add_row().cells
        for i, v in enumerate(row):
            cells[i].paragraphs[0].clear()
            _setfont(cells[i].paragraphs[0].add_run(str(v)), 13)
    if widths:
        for r in t.rows:
            for i, w in enumerate(widths):
                r.cells[i].width = Inches(w)
    return t


# ============ ปก ============
para("เอกสารแนวทางการพัฒนา", 22, True, WD_ALIGN_PARAGRAPH.CENTER, after=2)
para("ระบบรายงานการเงินแบบเว็บแอปพลิเคชัน", 22, True, WD_ALIGN_PARAGRAPH.CENTER, after=2)
para("บริษัท เจเอสพี คอนเนกซ์ จำกัด (JSP CONNX CO., LTD.)", 16, False, WD_ALIGN_PARAGRAPH.CENTER, after=2)
para("เชื่อมโยงข้อมูลจากโปรแกรม Express สู่ฐานข้อมูล SQL Server", 14, False, WD_ALIGN_PARAGRAPH.CENTER)
para("ฉบับร่างเพื่อพิจารณา | เฟส 1: งบการเงิน", 13, False, WD_ALIGN_PARAGRAPH.CENTER)
doc.add_paragraph()

# ============ 1 บทสรุปผู้บริหาร ============
h("1. บทสรุปผู้บริหาร")
para("ปัจจุบันบริษัทบันทึกข้อมูลบัญชีทั้งหมดในโปรแกรม Express และจัดทำงบการเงิน/รายงานภาษีด้วยการ "
     "ส่งออกข้อมูลมาทำต่อในไฟล์ Excel ขนาดใหญ่ (62 ชีต) ด้วยมือ ซึ่งใช้เวลามาก แก้ไขยาก และเสี่ยงต่อความผิดพลาด")
para("โครงการนี้เสนอให้พัฒนาเว็บแอปพลิเคชันภายในองค์กร โดย (1) ดึงข้อมูลที่จำเป็นจาก Express เข้าสู่ฐานข้อมูล "
     "SQL Server ผ่านการกดปุ่ม “Sync” (2) เก็บ logic การจัดทำงบไว้ในระบบ และ (3) ออกงบการเงิน/รายงานให้พนักงาน "
