ne-block}.modcard:hover .modlink span{transform:translateX(3px)}.tag{display:inline-block;font-size:11px;background:var(--brand-50);color:var(--brand-d);padding:2px 9px;border-radius:999px;font-weight:750;vertical-align:middle}

/* search + inputs */
.toolbar{display:flex;gap:14px;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap}.toolbar.card-lite{padding:16px;border-color:#dff4ff;background:rgba(255,255,255,.96)}.search{position:relative;flex:1;min-width:280px;margin:0}.search-ic{position:absolute;left:17px;top:50%;transform:translateY(-50%);color:#7aaabd;font-size:21px}.search input{width:100%;height:52px;padding:0 18px 0 48px;font-size:15px;border:1px solid #dbe8ef;border-radius:16px;background:#fff;color:var(--ink);transition:border-color .16s,box-shadow .16s}input,select{border:1px solid var(--line);border-radius:12px;background:#fff;color:var(--ink)}input:focus,select:focus{outline:none;border-color:var(--brand);box-shadow:0 0 0 4px rgba(56,189,248,.16)}

/* tables */
table.grid{width:100%;border-collapse:separate;border-spacing:0;background:transparent}table.grid th{background:linear-gradient(180deg,var(--brand-50),#f8fdff);text-align:left;padding:15px 16px;font-size:12px;font-weight:850;color:#527184;border-bottom:1px solid #dff4ff;letter-spacing:.04em;text-transform:uppercase}table.grid td{padding:15px 16px;border-top:1px solid #edf2f6;vertical-align:middle;background:#fff;transition:background .14s}table.grid tbody tr:first-child td{border-top:0}table.grid td.name{font-weight:800;color:var(--ink)}table.grid tr:hover td{background:#f8fdff}table.grid th.amt,table.grid td.amt{text-align:right;font-variant-numeric:tabular-nums}.table-card{border-color:#dff4ff;box-shadow:0 12px 32px rgba(15,23,42,.05)}.row-action{background:var(--brand-50);color:#0b83b5;border:1px solid var(--brand-100);box-shadow:none}.row-action:hover{background:linear-gradient(135deg,var(--brand),var(--brand-d));color:#fff;border-color:transparent;box-shadow:0 10px 20px rgba(56,189,248,.22)}.pagebar{display:flex;gap:16px;align-items:center;justify-content:flex-end;flex-wrap:wrap;color:#66788a}.pagebar select{padding:7px 30px 7px 10px;font-size:13px;border-color:#dbe8ef}.pager{display:flex;gap:7px;flex-wrap:wrap;margin-top:18px;justify-content:center}.pgbtn{padding:8px 13px;font-size:13px;border:1px solid var(--line);border-radius:10px;background:#fff;cursor:pointer;color:var(--ink);font-weight:700}.pgbtn:hover:not(:disabled){border-color:var(--brand);color:var(--brand)}.pgbtn.active{background:var(--brand);color:#fff;border-color:var(--brand)}.pgbtn:disabled{opacity:.45;cursor:default}

/* year cards */
.yearcards{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-top:14px}.yearcard{display:block;text-decoration:none;color:var(--ink);background:#fff;border:1px solid var(--line);border-radius:20px;padding:24px;text-align:center;box-shadow:var(--shadow-sm);transition:.16s}.yearcard:hover{color:var(--ink);border-color:var(--brand-100);box-shadow:var(--shadow);transform:translateY(-3px)}.yearcard.current{border-color:var(--brand);background:linear-gradient(135deg,var(--brand-50),#fff)}.yearcard .ythai{font-size:36px;font-weight:900;color:var(--brand-d);line-height:1}.yearcard .yce{color:var(--muted);font-size:13px;margin-top:8px}.yearcard .ytag{display:inline-flex;margin-top:12px;font-size:12px;color:var(--brand-d);background:var(--brand-50);border-radius:999px;padding:4px 10px;font-weight:800}

/* statement */
.stmt-head{display:flex;align-items:flex-start;gap:20px;flex-wrap:wrap;margin-bottom:16px}.stmt-head h1{margin:0}.period-badge{margin-left:auto;text-align:right;background:#fff;border:1px solid var(--line);border-radius:16px;padding:12px 16px;box-shadow:var(--shadow-sm)}.period-badge .py{font-size:12px;color:var(--muted)}.period-badge .pv{font-size:18px;font-weight:850;color:var(--ink)}.stmt-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:20px;margin-top:18px}.card h2{margin-top:0;color:var(--brand-d);text-align:center;border-bottom:1px solid var(--line);padding-bottom:13px;font-size:21px}.fs{width:100%;border-collapse:collapse;margin-bottom:10px}.fs td{padding:6px 0;font-size:16px}.fs td.amt{text-align:right;font-variant-numeric:tabular-nums;white-space:nowrap;font-family:Consolas,"SF Mono",monospace;font-size:15px}.fs tr.header td.lbl{font-weight:800}.fs tr.lvl1 td.lbl{padding-left:0}.fs tr.lvl2 td.lbl{padding-left:16px}.fs tr.lvl3 td.lbl{padding-left:32px}.fs tr.lvl4 td.lbl{padding-left:48px}.fs tr.lvl5 td.lbl{padding-left:64px}.fs tr.subtotal td{border-top:1px solid var(--line);font-weight:850;padding-top:8px}.fs tr.total td{border-top:2px solid var(--brand);font-weight:900;padding:9px 0;color:var(--brand-d)}.fs tr.grand td{color:var(--good)}.fs tr.aje td{color:var(--brand);font-style:italic}.adjtoggle{display:flex;gap:12px;align-items:center;margin:10px 0 16px;flex-wrap:wrap}

