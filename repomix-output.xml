<file path="reference/templates/financial/index.html">
{% extends "base.html" %}
{% block title %}เลือกบริษัท{% endblock %}
{% block breadcrumb %}
<nav class="crumb"><a href="/">🏠 หน้าหลัก</a> &rsaquo; <span>งบการเงิน</span></nav>
{% endblock %}
{% block content %}
<div class="stmt-head page-title">
  <div>
    <h1 class="financial-heading"><span class="heading-icon" aria-hidden="true">📊</span>งบการเงิน</h1>
  </div>
  <a class="btn ghost refresh-btn" href="/refresh?to=/financial/"><span aria-hidden="true">↻</span>รีเฟรชรายชื่อ</a>
</div>

<div class="toolbar card-lite">
  <form class="search" onsubmit="return false;">
    <span class="search-ic">⌕</span>
    <input type="text" id="q" placeholder="ค้นหาชื่อบริษัท / เลขผู้เสียภาษี / ที่เก็บข้อมูล..." oninput="onSearch()">
  </form>
  <div class="pagebar">
    <label class="muted small">แสดงหน้าละ
      <select id="perPage" onchange="setPerPage(this.value)">
        <option value="10">10</option>
        <option value="20">20</option>
        <option value="50">50</option>
      </select> รายการ
    </label>
    <span class="muted small" id="rangeInfo"></span>
  </div>
</div>

<div class="table-card">
  <table class="grid" id="tbl">
    <thead>
      <tr><th>ชื่อบริษัท</th><th>เลขประจำตัวผู้เสียภาษี</th><th>ที่เก็บข้อมูล</th><th></th></tr>
    </thead>
    <tbody>
      {% for c in companies %}
      <tr>
        <td class="name">{{ c.thai_name or c.name or c.code }}{% if not c.exists %} <span class="pill bad">ไม่พบโฟลเดอร์</span>{% endif %}</td>
        <td class="mono">{{ c.tax_id }}</td>
        <td class="mono pathcell">{{ c.path }}</td>
        <td class="right"><a class="btn sm row-action" href="/financial/company?id={{ c.id }}">เลือก →</a></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<nav class="pager" id="pager"></nav>

<script>
var perPage = 10, page = 1;

function allRows() {
  return Array.prototype.slice.call(document.querySelectorAll('#tbl tbody tr'));
}
function matchedRows() {
  var q = document.getElementById('q').value.toLowerCase();
  return allRows().filter(function(tr){
    return tr.innerText.toLowerCase().indexOf(q) >= 0;
  });
}
function render() {
  var rows = allRows();
  var matched = matchedRows();
  var total = matched.length;
  var pages = Math.max(1, Math.ceil(total / perPage));
  if (page > pages) page = pages;
  if (page < 1) page = 1;
  var start = (page - 1) * perPage;
  var end = start + perPage;
  rows.forEach(function(tr){ tr.style.display = 'none'; });
  matched.slice(start, end).forEach(function(tr){ tr.style.display = ''; });

  var info = document.getElementById('rangeInfo');
  info.textContent = total ? ('แสดง ' + (start + 1) + '–' + Math.min(end, total) + ' จาก ' + total + ' รายการ')
                           : 'ไม่พบรายการ';
  renderPager(pages);
}
function renderPager(pages) {
  var nav = document.getElementById('pager');
  nav.innerHTML = '';
  if (pages <= 1) return;
  function btn(label, target, opts) {
    opts = opts || {};
    var b = document.createElement('button');
    b.textContent = label;
    b.className = 'pgbtn' + (opts.active ? ' active' : '');
    if (opts.disabled) { b.disabled = true; }
    else { b.onclick = function(){ page = target; render(); }; }
    nav.appendChild(b);
  }
  btn('‹ ก่อนหน้า', page - 1, {disabled: page === 1});
  for (var i = 1; i <= pages; i++) btn(String(i), i, {active: i === page});
  btn('ถัดไป ›', page + 1, {disabled: page === pages});
}
function onSearch() { page = 1; render(); }
function setPerPage(v) { perPage = parseInt(v, 10) || 10; page = 1; render(); }

document.addEventListener('DOMContentLoaded', render);
</script>
{% endblock %}
</file>

<file path="reference/templates/financial/lease.html">
{% extends "base.html" %}
{% block title %}กระดาษทำการเจ้าหนี้เช่าซื้อ — {{ info.thai_name or company.name }}{% endblock %}
{% block breadcrumb %}
<nav class="crumb">
  <a href="/financial/">บริษัททั้งหมด</a> &rsaquo;
  <a href="/financial/company?id={{ cid }}">{{ company.name or company.code }}</a> &rsaquo;
  <a href="/financial/statement?id={{ cid }}&year={{ yearq }}">งบปี {{ year.year_thai }}</a> &rsaquo;
  <span>เจ้าหนี้เช่าซื้อ</span>
</nav>
{% endblock %}
{% block content %}
<div class="stmt-head">
  <div>
    <h1>กระดาษทำการเจ้าหนี้เช่าซื้อ</h1>
    <p class="muted">{{ info.thai_name or company.name }} &middot; ณ 31 ธันวาคม {{ year.year_thai }}</p>
  </div>
  <div class="actions no-print">
    <a class="btn ghost" href="/financial/statement?id={{ cid }}&year={{ yearq }}&adj=1">ดูงบหลังปรับปรุง</a>
  </div>
</div>
{% if notice == 'saved' %}<p class="ok-msg">บันทึกแล้ว — นำไปใช้ใน BAL2/งบหลังปรับปรุงเรียบร้อย</p>{% endif %}

<div class="resultbar">
  <div><span class="muted small">ส่วนถึงกำหนดใน 1 ปี</span><div class="big brand">{{ totals.current | money }}</div></div>
  <div><span class="muted small">ส่วนไม่หมุนเวียน</span><div class="big">{{ totals.noncurrent | money }}</div></div>
  <div><span class="muted small">รวมหนี้สินเช่าซื้อ (สุทธิ)</span><div class="big">{{ (totals.current + totals.noncurrent) | money }}</div></div>
</div>

<form method="post" action="/financial/lease/save" class="wp">
  <input type="hidden" name="id" value="{{ cid }}">
  <input type="hidden" name="year" value="{{ yearq }}">

  <h3 class="sec">สัญญาเช่าซื้อ</h3>
  <p class="muted small">กรอกเงื่อนไขสัญญา ระบบจะสร้างตารางตัดบัญชีลดต้นลดดอกและคำนวณส่วนถึงกำหนดใน 1 ปี (ยอดคงเหลือสิ้นปี − ยอดคงเหลืออีก 12 เดือน) &middot; หากต้องการกำหนดเอง ใส่ช่อง override</p>
  <table class="grid wptbl" id="contracts">
    <thead><tr>
      <th>ชื่อสัญญา</th><th class="amt">เงินต้น</th><th class="amt">ดอกเบี้ย/เดือน</th>
      <th class="amt">ค่างวด(เงินต้น+ดอก)</th><th class="amt">งวด</th><th>เริ่มงวด</th>
      <th class="amt">override current</th><th class="amt">override ไม่หมุนเวียน</th><th></th>
    </tr></thead>
    <tbody>
      {% for c in contracts %}
      <tr>
        <td><input type="text" name="lease_name" value="{{ c.name }}"></td>
        <td><input type="text" class="amt" name="lease_principal" value="{{ c.principal }}"></td>
        <td><input type="text" class="amt" name="lease_rate" value="{{ c.rate_month }}"></td>
        <td><input type="text" class="amt" name="lease_installment" value="{{ c.installment }}"></td>
        <td><input type="text" class="amt sm" name="lease_periods" value="{{ c.periods }}"></td>
        <td><input type="text" name="lease_start" value="{{ c.start }}" placeholder="YYYY-MM-DD"></td>
        <td><input type="text" class="amt" name="lease_cur_override" value="{{ c.current_override if c.current_override not in (none,'') else '' }}"></td>
        <td><input type="text" class="amt" name="lease_noncur_override" value="{{ c.noncurrent_override if c.noncurrent_override not in (none,'') else '' }}"></td>
        <td><button type="button" class="btn danger sm" onclick="delRow(this)">ลบ</button></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <button type="button" class="btn ghost sm" onclick="addContract()">+ เพิ่มสัญญา</button>

  <h3 class="sec">การจับคู่บัญชี Express (เพื่อแสดงสุทธิในงบ)</h3>
  <div class="tierbar">
    <label>รหัสเจ้าหนี้เช่าซื้อ (gross, คั่นด้วย ,)<input type="text" name="account_codes" value="{{ acct }}" placeholder="เช่น 21151"></label>
    <label>รหัสดอกเบี้ย/ภาษีซื้อรอตัด (สินทรัพย์)<input type="text" name="deferred_codes" value="{{ defacct }}" placeholder="เช่น 11513,11551"></label>
  </div>
  <p class="muted small">งบจะถอดเจ้าหนี้เช่าซื้อยอดเต็มและดอกเบี้ยรอตัดออก แล้วแสดงสุทธิ แยกส่วนถึงกำหนดใน 1 ปี / ไม่หมุนเวียน</p>

  <div class="actions"><button class="btn" type="submit">บันทึก</button></div>
</form>

{% for d in totals.details %}
{% if d.rows %}
<h3 class="sec">ตารางตัดบัญชี: {{ d.name }} &middot; คงเหลือสิ้นปี {{ d.balance | money }} (current {{ d.current | money }} / ไม่หมุนเวียน {{ d.noncurrent | money }})</h3>
<table class="grid sched" data-page-size="12">
  <thead><tr><th>งวด</th><th>วันที่</th><th class="amt">ยอดต้นงวด</th><th class="amt">ดอกเบี้ย</th><th class="amt">เงินต้น</th><th class="amt">คงเหลือ</th></tr></thead>
  <tbody>
    {% for r in d.rows %}
    <tr><td>{{ r.period }}</td><td class="mono small">{{ r.date }}</td>
      <td class="amt">{{ r.opening | money }}</td><td class="amt">{{ r.interest | money }}</td>
      <td class="amt">{{ r.principal | money }}</td><td class="amt">{{ r.closing | money }}</td></tr>
    {% endfor %}
  </tbody>
</table>
<div class="schedule-pager" aria-label="เปลี่ยนหน้าตารางตัดบัญชี"></div>
{% endif %}
{% endfor %}

<script>
function addContract(){
  var tb = document.querySelector('#contracts tbody');
  var tr = document.createElement('tr');
  tr.innerHTML =
    '<td><input type="text" name="lease_name"></td>'+
    '<td><input type="text" class="amt" name="lease_principal"></td>'+
    '<td><input type="text" class="amt" name="lease_rate"></td>'+
    '<td><input type="text" class="amt" name="lease_installment"></td>'+
    '<td><input type="text" class="amt sm" name="lease_periods"></td>'+
    '<td><input type="text" name="lease_start" placeholder="YYYY-MM-DD"></td>'+
    '<td><input type="text" class="amt" name="lease_cur_override"></td>'+
    '<td><input type="text" class="amt" name="lease_noncur_override"></td>'+
    '<td><button type="button" class="btn danger sm" onclick="delRow(this)">ลบ</button></td>';
  tb.appendChild(tr);
}
function delRow(btn){ btn.closest('tr').remove(); }

function setupSchedulePager(table) {
  var rows = Array.prototype.slice.call(table.querySelectorAll('tbody tr'));
  var perPage = parseInt(table.getAttribute('data-page-size'), 10) || 12;
  var pages = Math.max(1, Math.ceil(rows.length / perPage));
  var pager = table.nextElementSibling;
  var current = 1;
  if (!pager || !pager.classList.contains('schedule-pager') || pages <= 1) {
    if (pager) pager.style.display = 'none';
    rows.forEach(function(row){ row.style.display = ''; });
    return;
  }

  function render() {
    var start = (current - 1) * perPage;
    var end = start + perPage;
    rows.forEach(function(row, idx){
      row.style.display = idx >= start && idx < end ? '' : 'none';
    });
    pager.innerHTML = '';

    var info = document.createElement('span');
    info.className = 'muted small schedule-page-info';
    info.textContent = 'แสดงงวด ' + (start + 1) + '-' + Math.min(end, rows.length) + ' จาก ' + rows.length + ' งวด';
    pager.appendChild(info);

    function addButton(label, target, disabled, active) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'pgbtn' + (active ? ' active' : '');
      btn.textContent = label;
      btn.disabled = disabled;
      if (!disabled && !active) {
        btn.onclick = function(){ current = target; render(); };
      }
      pager.appendChild(btn);
    }

    addButton('‹ ก่อนหน้า', current - 1, current === 1, false);
    for (var i = 1; i <= pages; i++) addButton(String(i), i, false, i === current);
    addButton('ถัดไป ›', current + 1, current === pages, false);
  }

  render();
}

document.addEventListener('DOMContentLoaded', function(){
  Array.prototype.forEach.call(document.querySelectorAll('table.sched'), setupSchedulePager);
});
</script>
{% endblock %}
</file>

<file path="reference/templates/financial/reconcile.html">
{% extends "base.html" %}
{% block title %}กระทบยอด — {{ info.thai_name or company.name }}{% endblock %}
{% block breadcrumb %}
<nav class="crumb">
  <a href="/financial/">บริษัททั้งหมด</a> &rsaquo;
  <a href="/financial/company?id={{ cid }}">{{ company.name or company.code }}</a> &rsaquo;
  <a href="/financial/statement?id={{ cid }}&year={{ yearq }}">งบปี {{ year.year_thai }}</a> &rsaquo;
  <span>กระทบยอด</span>
</nav>
{% endblock %}
{% block content %}
<h1>กระทบยอด: Express ดิบ → หลังปรับปรุง</h1>
<p class="muted">{{ info.thai_name or company.name }} &middot; ปี {{ year.year_thai }} ({{ year.year }})</p>
{% if not has_adj %}<p class="warn">ยังไม่มีรายการปรับปรุง — ไปที่หน้า <a href="/financial/tax?id={{ cid }}&year={{ yearq }}">คำนวณภาษี</a> และ <a href="/financial/lease?id={{ cid }}&year={{ yearq }}">เจ้าหนี้เช่าซื้อ</a> เพื่อบันทึกก่อน</p>{% endif %}

<table class="grid recon">
  <thead><tr><th>รายการ</th><th class="amt">Express ดิบ</th><th class="amt">หลังปรับปรุง</th><th class="amt">ผลต่าง</th></tr></thead>
  <tbody>
    {% set rows = [
      ('รวมสินทรัพย์', raw.balance_sheet.total_assets, adj.balance_sheet.total_assets),
      ('รวมหนี้สิน', raw.balance_sheet.total_liabilities, adj.balance_sheet.total_liabilities),
      ('รวมส่วนของผู้ถือหุ้น', raw.balance_sheet.total_equity, adj.balance_sheet.total_equity),
      ('รวมหนี้สินและส่วนของผู้ถือหุ้น', raw.balance_sheet.total_liab_equity, adj.balance_sheet.total_liab_equity),
      ('กำไร (ขาดทุน) ก่อนภาษี', raw.income_statement.net_profit, adj.income_statement.pretax_profit),
      ('ภาษีเงินได้', 0, adj.income_statement.income_tax),
      ('กำไร (ขาดทุน) สุทธิ', raw.income_statement.net_profit, adj.income_statement.net_profit_after_tax),
    ] %}
    {% for name, a, b in rows %}
    <tr>
      <td>{{ name }}</td>
      <td class="amt">{{ a | money }}</td>
      <td class="amt">{{ b | money }}</td>
      <td class="amt muted">{{ (b - a) | money }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<h3 class="sec">รายการปรับปรุงที่นำมาใช้</h3>
<table class="grid">
  <thead><tr><th>รายการ (AJE)</th><th class="amt">จำนวน</th><th>กระทบ</th></tr></thead>
  <tbody>
    {% for r in adj.balance_sheet.asset_adjustments %}
    <tr><td>{{ r.name }}</td><td class="amt">{{ r.value | money }}</td><td class="muted small">สินทรัพย์</td></tr>
    {% endfor %}
    {% for r in adj.balance_sheet.adjustments %}
    <tr><td>{{ r.name }}</td><td class="amt">{{ r.value | money }}</td><td class="muted small">{{ 'หนี้สิน' if r.affects_total else 'แสดงผล (จัดประเภท)' }}</td></tr>
    {% endfor %}
    {% if not adj.balance_sheet.adjustments %}<tr><td colspan="3" class="muted">— ไม่มี —</td></tr>{% endif %}
  </tbody>
</table>

<p class="muted small">หมายเหตุ: รอบนี้ปรับเฉพาะ (1) ภาษีเงินได้ และ (2) แสดงหนี้สินเช่าซื้อสุทธิ/จัดประเภท — รายการปรับปรุงอื่นของผู้สอบบัญชียังไม่รวม งบหลังปรับปรุงจึงอาจยังไม่ตรงไฟล์ตรวจสอบทุกบรรทัด</p>
{% endblock %}
</file>

<file path="reference/templates/financial/statement.html">
{% extends "base.html" %}
{% block title %}งบการเงิน {{ info.thai_name or company.name }} ปี {{ year.year_thai }}{% endblock %}
{% block breadcrumb %}
<nav class="crumb">
  <a href="/financial/">บริษัททั้งหมด</a> &rsaquo;
  <a href="/financial/company?id={{ company.id }}">{{ company.name or company.code }}</a> &rsaquo;
  <span>ปี {{ year.year_thai or year.label }}</span>
</nav>
{% endblock %}
{% block content %}

<div class="stmt-head">
  <div>
    <h1>{{ info.thai_name or company.name or company.code }}</h1>
    <p class="muted">เลขผู้เสียภาษี {{ info.tax_id }}</p>
  </div>
  <div class="period-badge">
    <div class="py">สำหรับปีสิ้นสุด</div>
    <div class="pv">31 ธันวาคม {{ year.year_thai or '' }}</div>
  </div>
  <div class="actions no-print">
    <a class="btn ghost" href="/financial/company?id={{ company.id }}">เปลี่ยนปี</a>
    <a class="btn ghost" href="/financial/tax?id={{ cid }}&year={{ yearq }}">คำนวณภาษี</a>
    <a class="btn ghost" href="/financial/lease?id={{ cid }}&year={{ yearq }}">เจ้าหนี้เช่าซื้อ</a>
    <a class="btn ghost" href="/financial/reconcile?id={{ cid }}&year={{ yearq }}">กระทบยอด</a>
    <button class="btn" onclick="window.print()">พิมพ์ / บันทึก PDF</button>
  </div>
</div>

{% if has_adj %}
<div class="adjtoggle no-print">
  {% if adjusted %}
    <span class="pill ok">งบหลังปรับปรุง</span>
    <a class="btn ghost sm" href="/financial/statement?id={{ cid }}&year={{ yearq }}&adj=0">ดูงบดิบ (Express)</a>
  {% else %}
    <span class="pill">งบดิบ (Express)</span>
    <a class="btn ghost sm" href="/financial/statement?id={{ cid }}&year={{ yearq }}&adj=1">ดูงบหลังปรับปรุง</a>
  {% endif %}
</div>
{% endif %}

{% if not bs.balanced %}
<p class="warn">หมายเหตุ: สินทรัพย์ไม่เท่ากับหนี้สิน+ทุน (ส่วนต่าง {{ bs.diff | money }}) — ตรวจสอบยอดยกมา/รายการปิดบัญชีใน Express</p>
{% endif %}

<div class="stmt-grid">
  <!-- ===== งบแสดงฐานะการเงิน ===== -->
  <section class="card">
    <h2>งบแสดงฐานะการเงิน</h2>

    <h3 class="sec">สินทรัพย์</h3>
    <table class="fs">
      {% for r in bs.assets %}
      <tr class="lvl{{ r.level }}{{ ' header' if r.is_header }}">
        <td class="lbl">{{ r.name }}</td>
        <td class="amt">{{ r.value | money }}</td>
      </tr>
      {% endfor %}
      {% for r in bs.asset_adjustments %}
      <tr class="aje"><td class="lbl">ปรับปรุง: {{ r.name }}</td><td class="amt">{{ r.value | money }}</td></tr>
      {% endfor %}
      <tr class="total"><td class="lbl">รวมสินทรัพย์</td><td class="amt">{{ bs.total_assets | money }}</td></tr>
    </table>

    <h3 class="sec">หนี้สิน</h3>
    <table class="fs">
      {% for r in bs.liabilities %}
      <tr class="lvl{{ r.level }}{{ ' header' if r.is_header }}">
        <td class="lbl">{{ r.name }}</td>
        <td class="amt">{{ r.value | money }}</td>
      </tr>
      {% endfor %}
      {% for r in bs.adjustments %}
      <tr class="aje"><td class="lbl">ปรับปรุง: {{ r.name }}</td><td class="amt">{{ r.value | money }}</td></tr>
      {% endfor %}
      <tr class="subtotal"><td class="lbl">รวมหนี้สิน</td><td class="amt">{{ bs.total_liabilities | money }}</td></tr>
    </table>

    <h3 class="sec">ส่วนของผู้ถือหุ้น</h3>
    <table class="fs">
      {% for r in bs.equity %}
      <tr class="lvl{{ r.level }}{{ ' header' if r.is_header }}">
        <td class="lbl">{{ r.name }}</td>
        <td class="amt">{{ r.value | money }}</td>
      </tr>
      {% endfor %}
      <tr class="subtotal"><td class="lbl">รวมส่วนของผู้ถือหุ้น</td><td class="amt">{{ bs.total_equity | money }}</td></tr>
      <tr class="total"><td class="lbl">รวมหนี้สินและส่วนของผู้ถือหุ้น</td><td class="amt">{{ bs.total_liab_equity | money }}</td></tr>
    </table>
  </section>

  <!-- ===== งบกำไรขาดทุน ===== -->
  <section class="card">
    <h2>งบกำไรขาดทุน</h2>

    <h3 class="sec">รายได้</h3>
    <table class="fs">
      {% for r in pl.income %}
      <tr class="lvl{{ r.level }}{{ ' header' if r.is_header }}">
        <td class="lbl">{{ r.name }}</td>
        <td class="amt">{{ r.value | money }}</td>
      </tr>
      {% endfor %}
      <tr class="subtotal"><td class="lbl">รวมรายได้</td><td class="amt">{{ pl.total_income | money }}</td></tr>
    </table>

    <h3 class="sec">ค่าใช้จ่าย</h3>
    <table class="fs">
      {% for r in pl.expense %}
      <tr class="lvl{{ r.level }}{{ ' header' if r.is_header }}">
        <td class="lbl">{{ r.name }}</td>
        <td class="amt">{{ r.value | money }}</td>
      </tr>
      {% endfor %}
      <tr class="subtotal"><td class="lbl">รวมค่าใช้จ่าย</td><td class="amt">{{ pl.total_expense | money }}</td></tr>
    </table>

    <table class="fs">
      {% if pl.adjusted %}
      <tr class="subtotal"><td class="lbl">กำไร (ขาดทุน) ก่อนภาษี</td><td class="amt">{{ pl.pretax_profit | money }}</td></tr>
      <tr class="aje"><td class="lbl">หัก ภาษีเงินได้</td><td class="amt">{{ pl.income_tax | money }}</td></tr>
      <tr class="total grand"><td class="lbl">กำไร (ขาดทุน) สุทธิ</td><td class="amt">{{ pl.net_profit_after_tax | money }}</td></tr>
      {% else %}
      <tr class="total grand"><td class="lbl">กำไร (ขาดทุน) สุทธิ</td><td class="amt">{{ pl.net_profit | money }}</td></tr>
      {% endif %}
    </table>
  </section>
</div>
{% endblock %}
</file>

<file path="reference/templates/financial/tax.html">
{% extends "base.html" %}
{% block title %}คำนวณภาษีเงินได้ — {{ info.thai_name or company.name }}{% endblock %}
{% block breadcrumb %}
<nav class="crumb">
  <a href="/financial/">บริษัททั้งหมด</a> &rsaquo;
  <a href="/financial/company?id={{ cid }}">{{ company.name or company.code }}</a> &rsaquo;
  <a href="/financial/statement?id={{ cid }}&year={{ yearq }}">งบปี {{ year.year_thai }}</a> &rsaquo;
  <span>คำนวณภาษี</span>
</nav>
{% endblock %}
{% block content %}
<div class="stmt-head">
  <div>
    <h1>คำนวณภาษีเงินได้นิติบุคคล</h1>
    <p class="muted">{{ info.thai_name or company.name }} &middot; ปี {{ year.year_thai }} ({{ year.year }})</p>
  </div>
  <div class="actions no-print">
    <a class="btn ghost" href="/financial/statement?id={{ cid }}&year={{ yearq }}&adj=1">ดูงบหลังปรับปรุง</a>
  </div>
</div>
{% if notice == 'saved' %}<p class="ok-msg">บันทึกแล้ว — นำไปใช้ใน PL/งบหลังปรับปรุงเรียบร้อย</p>{% endif %}

<div class="resultbar">
  <div><span class="muted small">กำไรทางภาษี</span><div class="big">{{ result.taxable | money }}</div></div>
  <div><span class="muted small">ภาษีเงินได้</span><div class="big brand">{{ result.income_tax | money }}</div></div>
</div>

<form method="post" action="/financial/tax/save" class="wp">
  <input type="hidden" name="id" value="{{ cid }}">
  <input type="hidden" name="year" value="{{ yearq }}">

  <label class="fld">กำไร (ขาดทุน) ทางบัญชีก่อนภาษี
    <input type="text" name="profit_override" value="{{ tax.profit_override if tax.profit_override not in (none,'') else '' }}"
           placeholder="{{ '%.2f'|format(pretax) }} (ดึงจาก Express อัตโนมัติ)">
    <span class="muted small">เว้นว่าง = ใช้ค่าจาก Express ({{ pretax | money }})</span>
  </label>

  <h3 class="sec">บวก: รายการบวกกลับทางภาษี</h3>
  <table class="grid wptbl" id="addbacks">
    <thead><tr><th>รายการ</th><th class="amt">จำนวนเงิน</th><th></th></tr></thead>
    <tbody>
      {% for r in tax.addbacks %}
      <tr>
        <td><input type="text" name="addback_desc" value="{{ r.desc }}"></td>
        <td><input type="text" class="amt" name="addback_amount" value="{{ r.amount or '' }}"></td>
        <td><button type="button" class="btn danger sm" onclick="delRow(this)">ลบ</button></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <button type="button" class="btn ghost sm" onclick="addRow('addbacks','addback')">+ เพิ่มรายการบวกกลับ</button>

  <h3 class="sec">หัก: รายการหักทางภาษี</h3>
  <table class="grid wptbl" id="deductions">
    <thead><tr><th>รายการ</th><th class="amt">จำนวนเงิน</th><th></th></tr></thead>
    <tbody>
      {% for r in tax.deductions %}
      <tr>
        <td><input type="text" name="deduction_desc" value="{{ r.desc }}"></td>
        <td><input type="text" class="amt" name="deduction_amount" value="{{ r.amount or '' }}"></td>
        <td><button type="button" class="btn danger sm" onclick="delRow(this)">ลบ</button></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <button type="button" class="btn ghost sm" onclick="addRow('deductions','deduction')">+ เพิ่มรายการหัก</button>

  <h3 class="sec">อัตราภาษี (SME)</h3>
  <div class="tierbar">
    <label>ยกเว้นกำไรช่วงแรก (บาท)<input type="text" name="exempt" value="{{ result.tiers[0][1] }}"></label>
    <label>เพดานอัตรากลาง (บาท)<input type="text" name="midcap" value="{{ result.tiers[1][1] }}"></label>
    <label>อัตรากลาง<input type="text" name="rate_mid" value="{{ result.tiers[1][2] }}"></label>
    <label>อัตราสูง<input type="text" name="rate_high" value="{{ result.tiers[2][2] }}"></label>
  </div>
  <p class="muted small">สูตร: (กำไรทางภาษี − ยกเว้น) × อัตรา ตามขั้น เช่น (616,466.93 − 300,000) × 15% = 47,470.04</p>

  <div class="actions"><button class="btn" type="submit">บันทึก</button></div>
</form>

<script>
function addRow(tblId, prefix){
  var tb = document.querySelector('#'+tblId+' tbody');
  var tr = document.createElement('tr');
  tr.innerHTML = '<td><input type="text" name="'+prefix+'_desc"></td>'+
                 '<td><input type="text" class="amt" name="'+prefix+'_amount"></td>'+
                 '<td><button type="button" class="btn danger sm" onclick="delRow(this)">ลบ</button></td>';
  tb.appendChild(tr);
}
function delRow(btn){ btn.closest('tr').remove(); }
</script>
{% endblock %}
</file>

