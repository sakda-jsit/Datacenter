/* forms */
.addform,.wp{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:20px;box-shadow:var(--shadow-sm)}.addform{display:flex;gap:16px;align-items:flex-end;flex-wrap:wrap;margin-top:10px}.addform label,.wp .fld,.tierbar label{display:flex;flex-direction:column;font-size:13px;color:var(--muted);gap:7px}.addform input,.rowform input,.wp .fld input,.tierbar input,.wptbl input{padding:10px 12px;border:1px solid var(--line);border-radius:11px;background:#fff}.addform input{min-width:310px}.rowform{display:flex;gap:8px;align-items:center;flex-wrap:wrap}.rowform input[name=path]{min-width:240px}.rowform input{font-size:13px}.wp{margin-top:10px}.wp .fld{max-width:620px;margin-bottom:14px}.wptbl input{width:100%;font-size:13px}.wptbl input.amt{text-align:right}.wptbl input.sm{max-width:82px}.tierbar{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:14px;margin:10px 0}.resultbar{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px;background:linear-gradient(135deg,var(--brand-50),#fff);border:1px solid var(--brand-100);border-radius:20px;padding:16px;margin:14px 0}.resultbar>div{background:rgba(255,255,255,.7);border:1px solid var(--line);border-radius:16px;padding:14px}.resultbar .big{font-size:27px;font-weight:900;line-height:1.15}.resultbar .brand{color:var(--brand)}.sched td,.sched th{padding:6px 10px;font-size:13px}.recon td.amt{font-variant-numeric:tabular-nums}.trace{background:#0f172a;color:#dbeafe;padding:16px;border-radius:14px;overflow:auto;font-size:12px}
.schedule-pager{display:flex;align-items:center;justify-content:flex-end;gap:7px;flex-wrap:wrap;margin:10px 0 22px}.schedule-page-info{margin-right:6px}

/* coming soon */
.soonbox{text-align:center;max-width:620px;margin:60px auto;background:#fff;border:1px solid var(--line);border-radius:26px;padding:46px;box-shadow:var(--shadow)}.soonicon{font-size:62px;margin-bottom:10px}.soonbox .pill{margin:12px 0}.soonbox .btn{margin-top:18px}

/* responsive */
@media (max-width:980px){.stmt-grid{grid-template-columns:1fr}.hero{flex-direction:column}.hero-stats{width:100%}.stat{flex:1}.period-badge{margin-left:0;text-align:left}.actions{width:100%}}
@media (min-width:1600px){.modgrid{grid-template-columns:repeat(4,minmax(0,1fr))}}
@media (max-width:860px){body.app{display:block}.sidebar{position:fixed;left:0;top:0;transform:translateX(-105%);transition:transform .18s;width:292px}.sidebar-open .sidebar{transform:translateX(0)}.sidebar-open:before{content:"";position:fixed;inset:0;background:rgba(15,23,42,.38);z-index:19}.sidebar-collapsed .sidebar{width:292px}.sidebar-collapsed .brandtext,.sidebar-collapsed .brand > span:not(.logo),.sidebar-collapsed .brand small,.sidebar-collapsed .menutitle,.sidebar-collapsed .menuitem .ml,.sidebar-collapsed .menuitem .tag,.sidebar-collapsed .sidefoot{display:block}.sidebar-collapsed .sidebar-head{padding:18px 16px 10px;flex-direction:row}.sidebar-collapsed .brand{justify-content:flex-start;gap:13px;padding:8px 4px}.sidebar-collapsed .menu{align-items:stretch;padding-left:14px;padding-right:14px}.sidebar-collapsed .menuitem{justify-content:flex-start;padding:12px 13px}.content-toolbar{display:flex}.hamb{display:grid;place-items:center}.content-sidebar-toggle{display:none}.container{padding:12px 16px 20px}.content-toolbar{padding:12px 16px 0 16px}.hero{padding:24px;border-radius:22px}.toolbar{display:block}.pagebar{justify-content:space-between;margin-top:12px}.table-card{overflow-x:auto}.modgrid{grid-template-columns:1fr}.section-head,.page-title{display:block}.dashboard-head{margin-top:6px;margin-bottom:20px}.stmt-head{display:block}.stmt-head .btn{margin-top:10px}.actions .btn{margin-top:0}.addform input{min-width:100%}.pathcell{max-width:260px}}
@media (max-width:560px){body{font-size:16px}h1{font-size:28px}.hero-stats{flex-direction:column}.stat{text-align:left}.modcard{padding:18px}.resultbar{grid-template-columns:1fr}.fs td{font-size:14px}.fs td.amt{font-size:13px}}
@media (max-width:720px){.topbar{height:auto;min-height:64px;padding:10px 16px;align-items:flex-start}.topbar-left{flex:1;align-items:center}.topbar .crumb span:not(:last-child){display:none}.topbar-user{gap:8px}.user-meta small{display:none}.user-meta strong{max-width:112px}.logout-btn{width:38px;padding:0;font-size:0}.logout-btn:before{content:"ออก";font-size:12px}}
@media (max-width:420px){.topbar{gap:10px}.topbar .crumb{font-size:13px}.user-meta{display:none}.user-avatar{width:34px;height:34px;border-radius:10px}.logout-btn{height:34px;width:36px}}

/* typography tuning */
.brandtext{font-size:17px;font-weight:800;line-height:1.2}
.topbar .crumb{font-size:13px;line-height:1.45}
.user-meta strong{font-size:13px;font-weight:700;line-height:1.25}
.user-meta small{font-size:10.5px;line-height:1.25}
