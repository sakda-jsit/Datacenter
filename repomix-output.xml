using Datacenter.Application.Common.Interfaces;
using Datacenter.Application.Features.Import.DTOs;

namespace Datacenter.Infrastructure.Services;

/// <summary>
/// Reads Express Accounting DBF files (ISINFO, GLACC, GLBAL) using cp874 encoding.
///
/// Express DBF structure (reference: /reference/express):
///   ISINFO  — company info: THINAM, ENGNAM, TAXID, VATRAT, YEARTHAI
///   GLACC   — chart of accounts: ACCNUM, ACCNAM, ACCNAM2, LEVEL, PARENT, GROUP, ACCTYP
///   GLBAL   — trial balance: ACCNUM, BEGLY,
///             DEBIT1LY–DEBIT12LY, CREDIT1LY–CREDIT12LY  (prior year)
///             DEBIT1–DEBIT12,   CREDIT1–CREDIT12          (current year)
///             DEBIT1NY–DEBIT12NY, CREDIT1NY–CREDIT12NY  (next year)
///             DEBITCLS, CREDITCLS                         (closing entries, CUR only)
///
/// TODO: Install NuGet package "dBASE.NET" (or equivalent) and replace stub logic
///       with actual DBF reading.  The method signatures and DTO shapes are final.
/// </summary>
public class ExpressDbfAdapter : IExpressDbfAdapter
{
    private static readonly int[] Months = Enumerable.Range(1, 12).ToArray();

    public Task<bool> FolderIsValidAsync(string companyFolderPath, CancellationToken ct = default)
    {
        bool valid = Directory.GetFiles(companyFolderPath, "ISINFO.*", SearchOption.TopDirectoryOnly)
            .Any(f => f.EndsWith(".DBF", StringComparison.OrdinalIgnoreCase)
                   || f.EndsWith(".dbf", StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(valid);
    }

    public Task<ExpressCompanyInfoDto> ReadCompanyInfoAsync(string companyFolderPath, CancellationToken ct = default)
    {
