-- seed_statement_mapping.sql
-- สร้างอัตโนมัติจาก TB25 ในไฟล์ 2025_JSPC_FIN.xlsx (script: build_financials.py)
-- ตารางผูกเลขบัญชี -> รหัสบรรทัดงบการเงิน (REF)

-- 1) นิยามบรรทัดในงบ
MERGE statement_line AS t USING (VALUES
  (N'A1', N'เงินสดและรายการเทียบเท่าเงินสด', N'A', 11),
  (N'A2', N'เงินลงทุนระยะสั้น', N'A', 12),
  (N'A7', N'ลูกหนี้การค้าและลูกหนี้หมุนเวียนอื่น', N'A', 13),
  (N'A8', N'ลูกหนี้เงินให้กู้ยืมบุคคล/กิจการที่เกี่ยวข้อง', N'A', 14),
  (N'A3', N'สินค้าคงเหลือ', N'A', 15),
  (N'A4', N'สินทรัพย์หมุนเวียนอื่น', N'A', 16),
  (N'A9', N'เงินลงทุนระยะยาว', N'A', 21),
  (N'A5', N'ที่ดิน อาคารและอุปกรณ์', N'A', 22),
  (N'A10', N'สินทรัพย์ไม่มีตัวตน', N'A', 23),
  (N'A6', N'สินทรัพย์ไม่หมุนเวียนอื่น', N'A', 24),
  (N'L1', N'เจ้าหนี้การค้าและเจ้าหนี้หมุนเวียนอื่น', N'L', 31),
  (N'L5', N'ส่วนของหนี้สินตามสัญญาเช่าที่ถึงกำหนดชำระภายในหนึ่งปี', N'L', 32),
  (N'L3', N'เงินกู้ยืมระยะสั้น', N'L', 33),
  (N'L2', N'หนี้สินหมุนเวียนอื่น', N'L', 34),
  (N'L6', N'เงินกู้ยืมระยะยาว', N'L', 41),
  (N'L4', N'หนี้สินตามสัญญาเช่า', N'L', 42),
  (N'C1', N'ทุนที่ออกและชำระแล้ว', N'E', 51),
  (N'RE', N'กำไร (ขาดทุน) สะสม', N'E', 52),
  (N'I1', N'รายได้จากการขาย', N'I', 61),
  (N'I2', N'รายได้จากการให้บริการ', N'I', 62),
  (N'I3', N'รายได้ดอกเบี้ย', N'I', 63),
  (N'I4', N'รายได้อื่น', N'I', 64),
  (N'C', N'ต้นทุนขายหรือต้นทุนการให้บริการ', N'X', 71),
  (N'X1', N'ค่าใช้จ่ายในการขาย', N'X', 72),
  (N'X2', N'ค่าใช้จ่ายในการบริหาร', N'X', 73),
  (N'X3', N'ต้นทุนทางการเงิน', N'X', 74),
  (N'X4', N'ภาษีเงินได้', N'X', 75)
) AS s(ref_code, line_name, section, sort_order)
  ON t.ref_code = s.ref_code
WHEN MATCHED THEN UPDATE SET line_name=s.line_name, section=s.section, sort_order=s.sort_order
WHEN NOT MATCHED THEN INSERT (ref_code,line_name,section,sort_order) VALUES (s.ref_code,s.line_name,s.section,s.sort_order);

-- 2) ผูกเลขบัญชี -> REF
MERGE account_mapping AS t USING (VALUES
  (N'11110', N'Cash on Hand', N'A1'),
  (N'11141', N'S/A Kasikorn 700-2-41094-4 LOTUS AMATA', N'A1'),
  (N'11142', N'S/A AOMSIN 020218530804', N'A1'),
